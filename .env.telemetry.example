# Telemetry build-time configuration.
# Copy this file to `.env.telemetry` and fill in your Supabase project's
# REST endpoint URL + anon (insert-only) key. Both are picked up by
# esbuild and baked into dist/extension.js at build time.
#
# DO NOT commit `.env.telemetry` (it's already gitignored).
# DO NOT paste your service-role key here — that one goes in the
# dashboard's `.env.local`, never in the extension bundle.
#
# RLS on the events table restricts the anon key to INSERT only, so
# even though it ships in the bundle nobody can read or modify data
# with it.

# Project Settings → API → Project URL + /rest/v1/events
VIBE_CHECK_TELEMETRY_URL=https://YOUR-PROJECT-REF.supabase.co/rest/v1/events

# Project Settings → API → Project API keys → anon (public)
VIBE_CHECK_TELEMETRY_ANON_KEY=eyJhbGciOi...your-anon-key-here...
